# Strava OAuth — obtener en https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# URL pública del backend (accesible desde el navegador)
# Local: http://localhost:4000
# VPS:   https://api.tudominio.com
BACKEND_URL=http://localhost:4000

# Secreto para firmar sesiones JWT (genera uno con: openssl rand -hex 32)
SESSION_SECRET=
