# Dominios
FRONTEND_URL=https://coach.iawiki.app
BACKEND_URL=https://api.iawiki.app

# Base de datos (cámbia la contraseña)
DATABASE_URL=postgres://gptrainer:CAMBIA_ESTO@postgres:5432/gptrainer
POSTGRES_USER=gptrainer
POSTGRES_PASSWORD=CAMBIA_ESTO
POSTGRES_DB=gptrainer

# Redis
REDIS_URL=redis://redis:6379

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Seguridad (genera con: openssl rand -hex 32)
SESSION_SECRET=

# OpenRouter
OPENROUTER_API_KEY=

# Webhook Strava (el mismo que tienes en .env local)
STRAVA_WEBHOOK_VERIFY_TOKEN=
